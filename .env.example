# ============================================================
# AZ POOLARENA — Docker Compose Environment Template
# Copy thành .env và điền giá trị thực
# ============================================================

# ---- PostgreSQL ----
POSTGRES_DB=azpoolarena
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REPLACE_WITH_DB_PASSWORD
DB_PORT=5432

# ---- JWT (backend) ----
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET_96_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ---- Environment ----
TZ=Asia/Ho_Chi_Minh

# ---- Ports (thay đổi nếu bị conflict) ----
BACKEND_PORT=8000
FRONTEND_PORT=5173
POOLARENA_PORT=5174
MEMBER_PORT=5176
MQTT_PORT=1883
MQTT_WS_PORT=9001

# ---- CORS — IP máy dev để thiết bị LAN truy cập được ----
# Thay 192.168.1.187 bằng IP máy của bạn (ipconfig | grep IPv4)
CORS_ORIGINS=http://192.168.1.187:5173,http://192.168.1.187:5174,http://192.168.1.187:3000,http://192.168.1.187:5176,http://localhost:5173,http://localhost:5174,http://localhost:3000,http://localhost:5176

# ---- Security ----
INTERNAL_API_KEY=REPLACE_WITH_RANDOM_KEY
FRONTEND_URL=http://192.168.1.187:5173

# ---- Frontend API URLs — để thiết bị khác trong LAN gọi được backend ----
VITE_API_URL=http://192.168.1.187:8000
NEXT_PUBLIC_API_URL=http://192.168.1.187:8000
