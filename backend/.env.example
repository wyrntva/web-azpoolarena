# ============================================================
# AZ POOLARENA - Production Environment Config
# ============================================================
# Copy this file to .env on production server and fill in real values

# Database
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@localhost:5432/azpoolarena

# JWT — Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET_96_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Environment
ENV=production
PORT=8000

# CORS — Set to your domain (e.g. https://azpoolarena.com)
# When frontend is served by same Nginx, you can use the domain directly
CORS_ORIGINS=https://yourdomain.com

# MQTT (Mosquitto)
MQTT_URL=mqtt://localhost:1883

# Security
ALLOWED_HOSTS=*
FORCE_HTTPS=true
INTERNAL_API_KEY=REPLACE_WITH_RANDOM_KEY
FRONTEND_URL=https://yourdomain.com

# ============================================================
# OpenAI — AI Chatbot Module (Jarvis)
# ============================================================
# Lấy API key tại: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Model sử dụng — gpt-4o-mini (tiết kiệm), gpt-4o (mạnh hơn), gpt-5-mini (khi available)
# Xem đầy đủ: https://platform.openai.com/docs/models
OPENAI_MODEL=gpt-4o-mini

# ============================================================
# Facebook Messenger Webhook
# ============================================================
# Token tự đặt khi cấu hình webhook trong Facebook Developer Console
FB_VERIFY_TOKEN=your-verify-token-here

# Page Access Token — lấy từ Facebook Developer Console > Page > Access Token
FB_PAGE_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxx

# Số điện thoại cửa hàng (hiển thị khi chuyển sang nhân viên)
STORE_PHONE=0xxxxxxxxx
