# ============================================================
# AZ POOLARENA Backend — Environment Template
#
# Có 2 cách dùng file này:
#   1. Docker  → copy lên root .env (docker-compose tự đọc)
#   2. Local   → copy thành backend/.env (npm run start:dev)
#
# Tạo secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ============================================================

# ---- Database ----
# Docker:  DATABASE_URL=postgresql://postgres:password@db:5432/azpoolarena
# Local:   DATABASE_URL=postgresql://postgres:password@localhost:5432/azpoolarena
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@localhost:5432/azpoolarena

# ---- JWT ----
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET_96_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ---- Environment ----
ENV=development
PORT=8000

# ---- CORS ----
# Docker:  thêm http://192.168.1.187:5173,...
# Local:   dùng localhost
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,http://localhost:5176

# ---- MQTT ----
# Docker:  mqtt://mqtt:1883  (hostname nội bộ Docker)
# Local:   mqtt://localhost:1883
MQTT_URL=mqtt://localhost:1883

# ---- Security ----
ALLOWED_HOSTS=*
FORCE_HTTPS=false
INTERNAL_API_KEY=REPLACE_WITH_RANDOM_KEY
FRONTEND_URL=http://localhost:5173

# ============================================================
# OpenAI — AI Chatbot (Jarvis)
# https://platform.openai.com/api-keys
# ============================================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ============================================================
# Facebook Messenger Webhook
# ============================================================
FB_VERIFY_TOKEN=your-verify-token-here
FB_PAGE_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxx
STORE_PHONE=0xxxxxxxxx
