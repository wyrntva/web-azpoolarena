# ============================================================
# AZ POOLARENA — Production Docker Compose Root Env
# Copy thành .env và điền giá trị thực trước khi chạy
#   cp .env.prod.example .env
# ============================================================

# ---- PostgreSQL (phải khớp với backend/.env DATABASE_URL) ----
POSTGRES_DB=poolarena
POSTGRES_USER=poolarena
POSTGRES_PASSWORD=REPLACE_WITH_DB_PASSWORD

# ---- Next.js public API URL ----
NEXT_PUBLIC_API_URL=https://cms.poolarena.vn
