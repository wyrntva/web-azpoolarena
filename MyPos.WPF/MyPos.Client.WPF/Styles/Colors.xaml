<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Colors.xaml — PoolArena POS Color Palette
        Tương đương Tailwind custom colors + CSS variables trong Electron
    -->

    <!-- Primary Colors -->
    <Color x:Key="NavyDark">#030033</Color>
    <Color x:Key="NavyMid">#1A1A4E</Color>
    <Color x:Key="NavyLight">#2A2A6E</Color>
    <Color x:Key="PrimaryBlue">#0091FF</Color>
    <Color x:Key="CyanBlue">#00C0F9</Color>
    <Color x:Key="GreenSuccess">#0BBE5C</Color>
    <Color x:Key="RedDanger">#FF4444</Color>
    <Color x:Key="OrangeWarn">#FF7051</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BrushNavyDark" Color="{StaticResource NavyDark}" />
    <SolidColorBrush x:Key="BrushNavyMid" Color="{StaticResource NavyMid}" />
    <SolidColorBrush x:Key="BrushPrimaryBlue" Color="{StaticResource PrimaryBlue}" />
    <SolidColorBrush x:Key="BrushCyan" Color="{StaticResource CyanBlue}" />
    <SolidColorBrush x:Key="BrushGreen" Color="{StaticResource GreenSuccess}" />
    <SolidColorBrush x:Key="BrushRed" Color="{StaticResource RedDanger}" />
    <SolidColorBrush x:Key="BrushOrange" Color="{StaticResource OrangeWarn}" />
</ResourceDictionary>
