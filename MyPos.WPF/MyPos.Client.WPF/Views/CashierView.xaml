<UserControl x:Class="MyPos.Client.WPF.Views.CashierView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:MyPos.Client.WPF.ViewModels">

    <!--
        CashierView.xaml — Màn hình Thu Ngân chính
        Tương đương CashierScreen.tsx
        Layout: [Header] [Content: MenuSidebar | ProductGrid | CartPanel] [Footer]
        Background màu #030033 (xanh navy đậm) giống Electron UI
    -->

    <DockPanel Background="#030033" LastChildFill="True">

        <!-- ===== HEADER (tương đương <header className='homeHeader'>) ===== -->
        <Border DockPanel.Dock="Top" Background="#030033" Height="56" Padding="8,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Assets/logo-main.png" Height="36" Margin="8,0" />
                </StackPanel>

                <!-- Spacer -->
                <Grid Grid.Column="1" />

                <!-- Actions: Minimize + Close -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="4">
                    <Button Style="{StaticResource MaterialDesignIconButton}"
                            Command="{x:Static SystemCommands.MinimizeWindowCommand}"
                            Foreground="White" ToolTip="Thu nhỏ">
                        <materialDesign:PackIcon Kind="WindowMinimize" Width="20" Height="20" />
                    </Button>
                    <Button Style="{StaticResource MaterialDesignIconButton}"
                            Command="{Binding ExitCommand}"
                            Foreground="#FF7051" ToolTip="Thoát (ESC)">
                        <materialDesign:PackIcon Kind="Close" Width="20" Height="20" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== FOOTER (tương đương <CashierFooter />) ===== -->
        <Border DockPanel.Dock="Bottom" Background="#1A1A4E" Height="32" Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12" Foreground="#8888BB">
                    <Run Text="👤 " /><Run Text="{Binding UserName}" />
                </TextBlock>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16">
                    <TextBlock Text="{Binding TimeText}" VerticalAlignment="Center"
                               FontSize="13" FontWeight="SemiBold" Foreground="White" />
                    <TextBlock Text="{Binding DateText}" VerticalAlignment="Center"
                               FontSize="12" Foreground="#8888BB" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== MAIN CONTENT ===== -->
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Toolbar buttons (scroll up/down) = 141px -->
                <ColumnDefinition Width="141" />
                <!-- Product Grid = * -->
                <ColumnDefinition Width="*" />
                <!-- Cart Panel = 380px -->
                <ColumnDefinition Width="380" />
            </Grid.ColumnDefinitions>

            <!-- ---- CATEGORY SIDEBAR (tương đương Menu Sidebar trong Cashier) ---- -->
            <DockPanel Grid.Column="0" Margin="4">
                <!-- Scroll buttons -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,2">
                    <Button Content="▲" Width="70" Height="42"
                            Background="White" Foreground="#333"
                            BorderThickness="0"
                            Command="{Binding ScrollMenuUpCommand}"
                            IsEnabled="{Binding CanScrollMenuUp}" />
                    <Button Content="▼" Width="70" Height="42"
                            Background="White" Foreground="#333"
                            BorderThickness="0"
                            Command="{Binding ScrollMenuDownCommand}"
                            IsEnabled="{Binding CanScrollMenuDown}" />
                </StackPanel>

                <!-- Category List -->
                <ItemsControl ItemsSource="{Binding VisibleMenus}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="1" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Name}"
                                    FontSize="13"
                                    BorderThickness="0"
                                    Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="White" />
                                        <Setter Property="Foreground" Value="#333" />
                                        <Style.Triggers>
                                            <DataTrigger Value="True">
                                                <DataTrigger.Binding>
                                                    <MultiBinding Converter="{StaticResource EqualityConverter}">
                                                        <Binding />
                                                        <Binding Path="DataContext.SelectedCategory" RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                    </MultiBinding>
                                                </DataTrigger.Binding>
                                                <Setter Property="Background" Value="#0091FF" />
                                                <Setter Property="Foreground" Value="White" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>

            <!-- ---- PRODUCT GRID (tương đương ProductCard grid) ---- -->
            <Grid Grid.Column="1" Margin="4,0">
                <DockPanel>
                    <!-- Search Bar + Customer Bar -->
                    <Grid DockPanel.Dock="Top" Height="50" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Customer Count Bar -->
                        <Border Grid.Column="0" Background="White" CornerRadius="0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                                <TextBlock Text="👤" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="Khách lẻ" FontWeight="SemiBold" FontSize="13"
                                           Foreground="#333" VerticalAlignment="Center" />
                                <Separator Width="1" Margin="10,0" Background="#CCC" />
                                <TextBlock VerticalAlignment="Center" FontSize="13" Foreground="#333">
                                    <Run Text="{Binding CustomerCount}" />
                                    <Run Text=" Khách" />
                                </TextBlock>
                                <StackPanel VerticalAlignment="Center" Margin="4,0,0,0">
                                    <Button Content="▲" FontSize="8" Height="12" Padding="0"
                                            BorderThickness="0" Background="Transparent"
                                            Command="{Binding IncrementCustomersCommand}" />
                                    <Button Content="▼" FontSize="8" Height="12" Padding="0"
                                            BorderThickness="0" Background="Transparent"
                                            Command="{Binding DecrementCustomersCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Search Box -->
                        <Border Grid.Column="1" Background="White" Margin="4,0,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🔍" VerticalAlignment="Center"
                                           Margin="12,0,8,0" Foreground="#666" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="#333"
                                         VerticalAlignment="Center"
                                         FontSize="13"
                                         materialDesign:HintAssist.Hint="Nhập tên mặt hàng (F4)" />
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Products Scroll -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding FilteredProducts}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- ProductCard -->
                                    <Button Width="130" Height="100" Margin="2"
                                            Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Background="#1A1A4E"
                                            BorderThickness="0">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="12"
                                                       TextWrapping="Wrap" TextAlignment="Center"
                                                       Foreground="White" Margin="4,8,4,4" />
                                            <TextBlock FontSize="13" FontWeight="Bold"
                                                       TextAlignment="Center" Foreground="#00C0F9">
                                                <Run Text="{Binding Price, StringFormat={}{0:N0}}" />
                                                <Run Text="đ" />
                                            </TextBlock>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Grid>

            <!-- ---- CART PANEL (Right side) ---- -->
            <DockPanel Grid.Column="2" Background="White">

                <!-- Cart Header: Order Type + Table -->
                <Border DockPanel.Dock="Top" Background="#F5F5F5" Padding="12,8" BorderThickness="0,0,0,1"
                        BorderBrush="#E0E0E0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="🍽️" FontSize="16" VerticalAlignment="Center" />
                            <TextBlock Text="Tại bàn" FontWeight="SemiBold" FontSize="14" Foreground="#333"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock FontSize="12" Foreground="#0091FF" Margin="0,4,0,0">
                            <Run Text="{Binding SelectedTable, FallbackValue='Chưa chọn bàn'}" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Cart Items List -->
                <Border DockPanel.Dock="Bottom" Background="White">
                    <StackPanel>
                        <!-- Cart Tools Bar -->
                        <StackPanel Orientation="Horizontal" Background="#F9F9F9"
                                    Height="40" Margin="0">
                            <Button Width="40" Height="40" Content="🎁" BorderThickness="0"
                                    Background="Transparent" Foreground="#555" />
                            <Button Width="40" Height="40" Content="%" BorderThickness="0"
                                    Background="Transparent" Foreground="#555" />
                            <Button Width="40" Height="40" Content="🏷️" BorderThickness="0"
                                    Background="Transparent" Foreground="#555" />
                            <Button Width="40" Height="40" Content="✏️" BorderThickness="0"
                                    Background="Transparent" Foreground="#555" />
                        </StackPanel>

                        <!-- Total Row -->
                        <Border Background="#F5F5F5" Padding="12,10">
                            <Grid>
                                <TextBlock Text="Tổng tiền" FontSize="14" FontWeight="SemiBold"
                                           Foreground="#333" VerticalAlignment="Center" />
                                <TextBlock HorizontalAlignment="Right" FontSize="20" FontWeight="Bold" Foreground="#0086FF">
                                    <Run Text="{Binding CartTotal, StringFormat={}{0:N0}}" />
                                    <Run Text="đ" />
                                </TextBlock>
                            </Grid>
                        </Border>

                        <!-- Action Buttons (F1/F2/F3/ESC) -->
                        <Grid Height="60">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Background="#FFE8E4" Foreground="#FF7051"
                                    BorderThickness="0" FontSize="12"
                                    Command="{Binding ExitCommand}">
                                <StackPanel>
                                    <TextBlock Text="Thoát" FontWeight="SemiBold" />
                                    <TextBlock Text="(ESC)" FontSize="9" />
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="1" Background="{Binding HasCartItems, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#0BBE5C|#EEE'}"
                                    Foreground="{Binding HasCartItems, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='White|#333'}"
                                    BorderThickness="0" FontSize="12"
                                    Command="{Binding SaveOrderCommand}">
                                <StackPanel>
                                    <TextBlock Text="Lưu đơn" FontWeight="SemiBold" />
                                    <TextBlock Text="(F3)" FontSize="9" />
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="2"
                                    Background="{Binding HasCartItems, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#00C0F9|#EEE'}"
                                    Foreground="{Binding HasCartItems, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='White|#333'}"
                                    BorderThickness="0" FontSize="12">
                                <StackPanel>
                                    <TextBlock Text="Lưu &amp; T.Tính" FontWeight="SemiBold" />
                                    <TextBlock Text="(F2)" FontSize="9" />
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="3"
                                    Background="{Binding HasCartItems, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#0086FF|#EEE'}"
                                    Foreground="{Binding HasCartItems, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='White|#333'}"
                                    BorderThickness="0" FontSize="14"
                                    IsEnabled="{Binding HasCartItems}"
                                    Command="{Binding CheckoutCommand}">
                                <StackPanel>
                                    <TextBlock Text="Thanh toán" FontWeight="Bold" />
                                    <TextBlock Text="(F1)" FontSize="9" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Cart Items -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Cart}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- CartLineItem row -->
                                <Border BorderBrush="#F0F0F0" BorderThickness="0,0,0,1"
                                        Padding="8,6"
                                        Background="{Binding DataContext.SelectedLine, RelativeSource={RelativeSource AncestorType=ItemsControl},
                                                     Converter={StaticResource SelectedBrushConverter}, ConverterParameter={Binding}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Product.Name}" FontWeight="SemiBold"
                                                       FontSize="13" Foreground="#333" />
                                            <TextBlock FontSize="12" Foreground="#888">
                                                <Run Text="{Binding Product.Price, StringFormat={}{0:N0}}" /><Run Text="đ" />
                                            </TextBlock>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                            <Button Content="-" Width="28" Height="28"
                                                    FontSize="16" FontWeight="Bold"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    Command="{Binding DataContext.DecrementQtyCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" />
                                            <TextBlock Text="{Binding Qty}" Width="28"
                                                       TextAlignment="Center" VerticalAlignment="Center"
                                                       FontWeight="Bold" FontSize="14" Foreground="#333" />
                                            <Button Content="+" Width="28" Height="28"
                                                    FontSize="16" FontWeight="Bold"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    Command="{Binding DataContext.IncrementQtyCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Grid>

    </DockPanel>
</UserControl>
