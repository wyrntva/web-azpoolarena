<Window x:Class="MyPos.Client.WPF.Views.ShellView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:MyPos.Client.WPF.ViewModels"
        xmlns:views="clr-namespace:MyPos.Client.WPF.Views"
        Title="POS Thu Ngân - AZ POOLARENA"
        WindowState="Maximized"
        WindowStyle="None"
        Background="#030033"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontFamily="{materialDesign:MaterialDesignFont}"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- DataTemplate Selector: map ViewModel → View -->
        <!-- Tương đương renderScreen() switch trong App.tsx -->
        <DataTemplate DataType="{x:Type vm:ActivationViewModel}">
            <views:ActivationView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LockViewModel}">
            <views:LockView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <views:HomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CashierViewModel}">
            <views:CashierView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TableLayoutViewModel}">
            <views:TableLayoutView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AttendanceViewModel}">
            <views:AttendanceView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <!-- Main Content — switches View based on CurrentViewModel type -->
        <ContentControl Content="{Binding CurrentViewModel}"
                         Focusable="False" />

        <!-- Scoreboard Approval Overlay Modal -->
        <!-- Tương đương <ScoreboardApprovalModal /> luôn render trong App.tsx -->
        <materialDesign:DialogHost IsOpen="{Binding CurrentPendingScoreboardOrder, Converter={StaticResource NullToBoolConverter}}"
                                    Background="#88000000">
            <materialDesign:DialogHost.DialogContent>
                <views:ScoreboardApprovalDialog DataContext="{Binding}" />
            </materialDesign:DialogHost.DialogContent>
        </materialDesign:DialogHost>
    </Grid>
</Window>
