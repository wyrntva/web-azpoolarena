<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MyPos.Client.Avalonia.ViewModels"
             xmlns:views="using:MyPos.Client.Avalonia.Views"
             x:Class="MyPos.Client.Avalonia.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://MyPos.Client.Avalonia/Styles/AppStyles.axaml" />
    </Application.Styles>

    <!--
        DataTemplates: map ViewModel → View
        Tương đương renderScreen() switch trong App.tsx
        Hoặc DataTemplate trong WPF ShellView.xaml
    -->
    <Application.DataTemplates>
        <DataTemplate DataType="{x:Type vm:ActivationViewModel}">
            <views:ActivationView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LockViewModel}">
            <views:LockView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <views:HomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CashierViewModel}">
            <views:CashierView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TableLayoutViewModel}">
            <views:TableLayoutView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AttendanceViewModel}">
            <views:AttendanceView />
        </DataTemplate>
    </Application.DataTemplates>
</Application>
