<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MyPos.Client.Avalonia.Views.HomeView">
  <!--
    HomeView.axaml — Ported from HomeScreen.tsx + home.css
    Layout: [Header #030033] + [Main: Grid + Sidebar] + [Footer #030033]
    Sidebar right: dark navy, filter buttons
    OrderCard: 255x200 white card with blue top border + ribbon
  -->
  <DockPanel>

    <!-- ===== HEADER (homeHeader) ===== -->
    <Border DockPanel.Dock="Top"
            Background="#030033"
            Height="55"
            Padding="24,0">
      <Grid ColumnDefinitions="Auto,*,Auto">

        <!-- Left: Menu + Logo + Tabs -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="24" VerticalAlignment="Center">
          <!-- Menu hamburger -->
          <Button Classes="iconBtn" Content="☰" FontSize="20"/>

          <!-- Logo -->
          <Border Width="50" Height="50" VerticalAlignment="Center">
            <TextBlock Text="🎱" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>

          <!-- Tabs: Tất cả đơn / Sơ đồ bàn / Đặt bàn / Dashboard / Chấm công -->
          <StackPanel Orientation="Horizontal" Spacing="0">
            <Button Content="Tất cả đơn" Classes="homeTab"
                    Command="{Binding SetFilterCommand}" CommandParameter="all"/>
            <Button Content="Sơ đồ bàn" Classes="homeTab"/>
            <Button Content="Đặt bàn" Classes="homeTab"/>
            <Button Content="Bảng điều khiển" Classes="homeTab"/>
            <Button Content="Chấm công" Classes="homeTab"/>
          </StackPanel>
        </StackPanel>

        <!-- Right: Globe + Bell + Minimize + Close -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
          <Button Classes="iconBtn" Content="🌐"/>
          <Button Classes="iconBtn" Content="🔔"/>
          <Button Classes="iconBtn" Content="—"/>
          <Button Classes="iconBtn" Content="✕" Foreground="#FF7051"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ===== FOOTER (homeFooter) ===== -->
    <Border DockPanel.Dock="Bottom"
            Background="#030033"
            Height="55"
            Padding="24,0">
      <Grid ColumnDefinitions="*,*,*">
        <!-- Left: User -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Border Width="32" Height="32" CornerRadius="16" Background="#1AFFFFFF">
            <TextBlock Text="👤" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <TextBlock Text="{Binding UserName, FallbackValue='Nhân viên POS'}"
                     FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Center: Brand -->
        <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="0">
          <TextBlock Text="AZ POOLARENA" FontSize="16" FontWeight="Bold"
                     Foreground="White" TextAlignment="Center" LetterSpacing="0.5"/>
        </StackPanel>

        <!-- Right: Time + Date -->
        <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
          <TextBlock Text="{Binding TimeDisplay}" FontSize="13" Foreground="White" TextAlignment="Right"/>
          <TextBlock Text="{Binding DateDisplay}" FontSize="13" Foreground="White" TextAlignment="Right"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ===== MAIN: Order Grid + Sidebar ===== -->
    <Grid ColumnDefinitions="*,320">

      <!-- Order Grid (homeGrid) -->
      <ScrollViewer Grid.Column="0" Background="#E8E8E8">
        <Panel>
          <!-- Empty state -->
          <StackPanel IsVisible="{Binding HasNoOrders}"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                      Spacing="16">
            <TextBlock Text="🎱" FontSize="72" HorizontalAlignment="Center"/>
            <TextBlock Text="Chưa có đơn hàng nào"
                       FontSize="24" FontWeight="Bold"
                       Foreground="#64748b"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Nhấn &quot;Tạo đơn mới&quot; ở bên phải để bắt đầu"
                       FontSize="15" Foreground="#94a3b8"
                       HorizontalAlignment="Center"/>
          </StackPanel>

          <!-- Order Cards -->
          <ItemsControl ItemsSource="{Binding FilteredOrders}"
                        IsVisible="{Binding HasOrders}"
                        Margin="10">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <!-- OrderCard: white, 255x200, blue top border -->
                <Border Width="255" Height="200"
                        Margin="5"
                        CornerRadius="12"
                        BorderBrush="#0091FF"
                        BorderThickness="0,4,0,0"
                        BoxShadow="0 10px 15px -3px #1A000000">
                  <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                      <GradientStop Color="#FFFFFF" Offset="0"/>
                      <GradientStop Color="#F8FAFC" Offset="1"/>
                    </LinearGradientBrush>
                  </Border.Background>

                  <Button Background="Transparent" BorderThickness="0"
                          Padding="0"
                          HorizontalContentAlignment="Stretch"
                          VerticalContentAlignment="Stretch"
                          Command="{Binding $parent[ItemsControl].DataContext.OpenCashierCommand}"
                          CommandParameter="{Binding}">
                    <Grid RowDefinitions="50,50,50,50">

                      <!-- Row 0: Header (ribbon + area name) -->
                      <Border Grid.Row="0"
                              BorderBrush="#14000000" BorderThickness="0,0,0,1">
                        <Panel>
                          <!-- Blue ribbon -->
                          <Border Width="32" Height="45"
                                  HorizontalAlignment="Left"
                                  Margin="8,-4,0,0"
                                  VerticalAlignment="Top"
                                  ZIndex="2">
                            <Border.Background>
                              <SolidColorBrush Color="#0091FF"/>
                            </Border.Background>
                            <Border.Clip>
                              <PathGeometry>
                                M0,0 L32,0 L32,38 L16,45 L0,38 Z
                              </PathGeometry>
                            </Border.Clip>
                            <TextBlock Text="🍽" FontSize="14"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Top"
                                       Margin="0,8,0,0"/>
                          </Border>

                          <!-- Area name -->
                          <TextBlock Text="{Binding AreaName, FallbackValue='AZ POOLARENA'}"
                                     FontWeight="Bold" FontSize="15"
                                     Foreground="#0f172a"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>
                        </Panel>
                      </Border>

                      <!-- Row 1: Table name -->
                      <Border Grid.Row="1" BorderBrush="#14000000" BorderThickness="0,0,0,1">
                        <TextBlock Text="{Binding TableDisplayName}"
                                   FontWeight="ExtraBold"
                                   FontSize="22"
                                   Foreground="#0f172a"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   LetterSpacing="-0.3"/>
                      </Border>

                      <!-- Row 2: Time + Payment info -->
                      <Border Grid.Row="2" BorderBrush="#14000000" BorderThickness="0,0,0,1"
                              Padding="16,0">
                        <Grid ColumnDefinitions="*,*">
                          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="⏰" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Elapsed, FallbackValue='00:00:00'}"
                                       FontSize="13" FontWeight="Medium"
                                       Foreground="#0f172a" VerticalAlignment="Center"/>
                          </StackPanel>
                          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                                      HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="💵" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding PaymentInfo}"
                                       FontSize="13" FontWeight="Medium"
                                       Foreground="#0f172a" VerticalAlignment="Center"/>
                          </StackPanel>
                        </Grid>
                      </Border>

                      <!-- Row 3: Footer actions -->
                      <Grid Grid.Row="3" ColumnDefinitions="Auto,*">
                        <Button Grid.Column="0" Content="⋯"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#635BFF" FontSize="20"
                                Width="36" Height="36"/>
                        <Button Grid.Column="1" Content="Thanh toán"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#635BFF" FontWeight="Bold"
                                FontSize="13"
                                HorizontalContentAlignment="Center"/>
                      </Grid>
                    </Grid>
                  </Button>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Panel>
      </ScrollViewer>

      <!-- ===== RIGHT SIDEBAR (homeSidebar) ===== -->
      <Border Grid.Column="1"
              Background="#030033"
              Padding="24"
              BorderBrush="#1AFFFFFF"
              BorderThickness="1,0,0,0">
        <DockPanel>

          <!-- Create Order Button -->
          <Button DockPanel.Dock="Top"
                  Classes="createOrderBtn"
                  Margin="0,0,0,16"
                  Command="{Binding NewOrderCommand}">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="+" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
              <TextBlock Text="Tạo đơn mới" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <!-- Divider -->
          <Border DockPanel.Dock="Top" Height="1" Background="#1AFFFFFF" Margin="0,0,0,12"/>

          <!-- Scroll nav buttons (bottom) -->
          <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,12,*" Margin="0,12,0,0">
            <Button Grid.Column="0" Content="›" Classes="scrollBtn" FontSize="20"/>
            <Button Grid.Column="2" Content="‹" Classes="scrollBtn" FontSize="20"/>
          </Grid>

          <!-- Filter Buttons -->
          <ScrollViewer>
            <StackPanel Spacing="12">
              <!-- All orders -->
              <Button Classes="filterBtn" Command="{Binding SetFilterCommand}" CommandParameter="all">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="Tất cả đơn" FontSize="15" FontWeight="SemiBold"
                             Foreground="White" VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="1" Text="{Binding Orders.Count}"
                             FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Top"/>
                </Grid>
              </Button>

              <!-- Small filter row 1 -->
              <Grid ColumnDefinitions="*,12,*">
                <Button Grid.Column="0" Classes="filterBtnSmall"
                        Command="{Binding SetFilterCommand}" CommandParameter="pending-payment">
                  <StackPanel>
                    <TextBlock Text="Chờ thanh toán" FontSize="12" FontWeight="SemiBold" Foreground="#030033"/>
                    <TextBlock Text="{Binding Stats.PendingPayment}" FontSize="11" Foreground="#635BFF" FontWeight="Bold"/>
                  </StackPanel>
                </Button>
                <Button Grid.Column="2" Classes="filterBtnSmall"
                        Command="{Binding SetFilterCommand}" CommandParameter="pending-confirm">
                  <StackPanel>
                    <TextBlock Text="Chờ xác nhận" FontSize="12" FontWeight="SemiBold" Foreground="#030033"/>
                    <TextBlock Text="{Binding Stats.PendingConfirm}" FontSize="11" Foreground="#635BFF" FontWeight="Bold"/>
                  </StackPanel>
                </Button>
              </Grid>

              <!-- Small filter row 2 -->
              <Grid ColumnDefinitions="*,12,*">
                <Button Grid.Column="0" Classes="filterBtnSmall">
                  <StackPanel>
                    <TextBlock Text="Order" FontSize="12" FontWeight="SemiBold" Foreground="#030033"/>
                    <TextBlock Text="0" FontSize="11" Foreground="#635BFF" FontWeight="Bold"/>
                  </StackPanel>
                </Button>
                <Button Grid.Column="2" Classes="filterBtnSmall">
                  <StackPanel>
                    <TextBlock Text="Đặt bàn" FontSize="12" FontWeight="SemiBold" Foreground="#030033"/>
                    <TextBlock Text="0" FontSize="11" Foreground="#635BFF" FontWeight="Bold"/>
                  </StackPanel>
                </Button>
              </Grid>

              <!-- Dine-in / Takeaway row -->
              <Grid ColumnDefinitions="*,12,*">
                <Button Grid.Column="0" Height="70" CornerRadius="6"
                        Background="#1AFFFFFF" BorderThickness="0"
                        Command="{Binding SetFilterCommand}" CommandParameter="dine-in">
                  <StackPanel HorizontalAlignment="Center" Spacing="2">
                    <TextBlock Text="🍽" FontSize="24" HorizontalAlignment="Center"/>
                    <TextBlock Text="Tại bàn" FontSize="12" Foreground="#635BFF" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Stats.DineIn}" FontSize="11" Foreground="#635BFF" FontWeight="Bold" HorizontalAlignment="Center"/>
                  </StackPanel>
                </Button>
                <Button Grid.Column="2" Height="70" CornerRadius="6"
                        Background="#1AFFFFFF" BorderThickness="0"
                        Command="{Binding SetFilterCommand}" CommandParameter="takeaway">
                  <StackPanel HorizontalAlignment="Center" Spacing="2">
                    <TextBlock Text="🥡" FontSize="24" HorizontalAlignment="Center"/>
                    <TextBlock Text="Mang đi" FontSize="12" Foreground="#f59e0b" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Stats.Takeaway}" FontSize="11" Foreground="#f59e0b" FontWeight="Bold" HorizontalAlignment="Center"/>
                  </StackPanel>
                </Button>
              </Grid>

              <!-- Divider -->
              <Border Height="1" Background="#1AFFFFFF"/>

              <!-- White AZ Button -->
              <Button Classes="filterBtn"
                      Background="White" Foreground="#030033"
                      HorizontalAlignment="Stretch">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="AZ" FontSize="15" FontWeight="SemiBold" Foreground="#030033"/>
                  <TextBlock Grid.Column="1" Text="0" FontSize="12" Foreground="#635BFF" FontWeight="Bold"/>
                </Grid>
              </Button>
            </StackPanel>
          </ScrollViewer>
        </DockPanel>
      </Border>
    </Grid>
  </DockPanel>
</UserControl>
