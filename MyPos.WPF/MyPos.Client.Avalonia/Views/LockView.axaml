<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MyPos.Client.Avalonia.Views.LockView"
             Background="Transparent">
  <!--
    LockView.axaml — Ported from LockScreen.tsx + lock.css
    Layout: 2 cột (Left: clock/brand | Right: PIN panel)
    Background: gradient #e0f2fe -> #bae6fd -> #93c5fd
  -->

  <Grid Background="#e0f2fe"
        RowDefinitions="*">
    <Grid.Background>
      <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#e0f2fe" Offset="0"/>
        <GradientStop Color="#bae6fd" Offset="0.5"/>
        <GradientStop Color="#93c5fd" Offset="1"/>
      </LinearGradientBrush>
    </Grid.Background>

    <Grid ColumnDefinitions="*,460" Margin="24">

      <!-- ===== LEFT PANEL: Brand + Clock ===== -->
      <Grid Grid.Column="0" RowDefinitions="Auto,*,Auto" Margin="24">

        <!-- Brand Row -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,32">
          <Border Width="14" Height="14" CornerRadius="7" Margin="0,10,0,0">
            <Border.Background>
              <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#635BFF" Offset="0"/>
                <GradientStop Color="#7c75ff" Offset="1"/>
              </LinearGradientBrush>
            </Border.Background>
          </Border>
          <StackPanel Spacing="4">
            <TextBlock Text="AZ POOLARENA"
                       FontSize="36" FontWeight="ExtraBold"
                       Foreground="#0f172a"
                       LetterSpacing="-1.5"/>
            <TextBlock Text="Tháp Đông - CC Học Viện Quốc Phòng, Phường Xuân La, Quận Tây Hồ, Thành phố Hà Nội"
                       FontSize="15" FontWeight="Medium"
                       Foreground="#475569"
                       TextWrapping="Wrap"
                       MaxWidth="600"/>
          </StackPanel>
        </StackPanel>

        <!-- Clock (center of left panel) -->
        <StackPanel Grid.Row="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="8">
          <TextBlock Text="{Binding TimeText}"
                     FontSize="160" FontWeight="ExtraLight"
                     Foreground="#0f172a"
                     LetterSpacing="-6"
                     HorizontalAlignment="Center"
                     TextAlignment="Center"/>
          <TextBlock Text="{Binding DateText}"
                     FontSize="20" FontWeight="Medium"
                     Foreground="#475569"
                     HorizontalAlignment="Center"
                     TextAlignment="Center"/>
        </StackPanel>

        <!-- Footer (version, hotline) -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" Spacing="4">
            <TextBlock Text="Hotline: 1900 6750" FontSize="15" FontWeight="Medium" Foreground="#475569"/>
            <TextBlock Text="Mã cửa hàng: 72405" FontSize="15" FontWeight="Medium" Foreground="#475569"/>
            <TextBlock Text="Version: 1.0.0" FontSize="15" FontWeight="Medium" Foreground="#475569"/>
          </StackPanel>
          <TextBlock Grid.Column="1" Text="PoolArena POS — .NET Avalonia"
                     FontSize="12" Foreground="#64748b"
                     VerticalAlignment="Bottom"/>
        </Grid>
      </Grid>

      <!-- ===== RIGHT PANEL: PIN Panel ===== -->
      <Border Grid.Column="1"
              VerticalAlignment="Center"
              Background="White"
              CornerRadius="24"
              Padding="24"
              BoxShadow="0 25px 50px -12px #40000000">

        <StackPanel Spacing="0">

          <!-- PIN Dots Display -->
          <Border Height="100" CornerRadius="12" Margin="0,0,0,20">
            <Border.Background>
              <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#635BFF" Offset="0"/>
                <GradientStop Color="#7c75ff" Offset="1"/>
              </LinearGradientBrush>
            </Border.Background>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="20">
              <Border Classes="pinDot" Name="Dot1"/>
              <Border Classes="pinDot" Name="Dot2"/>
              <Border Classes="pinDot" Name="Dot3"/>
              <Border Classes="pinDot" Name="Dot4"/>
            </StackPanel>
          </Border>

          <!-- PIN Pad -->
          <Grid RowDefinitions="76,12,76,12,76,12,76" ColumnDefinitions="*,12,*,12,*">
            <!-- Row 1: 1 2 3 -->
            <Button Grid.Row="0" Grid.Column="0" Content="1" Classes="keyBtn" Command="{Binding AppendDigitCommand}" CommandParameter="1"/>
            <Button Grid.Row="0" Grid.Column="2" Content="2" Classes="keyBtn" Command="{Binding AppendDigitCommand}" CommandParameter="2"/>
            <Button Grid.Row="0" Grid.Column="4" Content="3" Classes="keyBtn" Command="{Binding AppendDigitCommand}" CommandParameter="3"/>
            <!-- Row 2: 4 5 6 -->
            <Button Grid.Row="2" Grid.Column="0" Content="4" Classes="keyBtn" Command="{Binding AppendDigitCommand}" CommandParameter="4"/>
            <Button Grid.Row="2" Grid.Column="2" Content="5" Classes="keyBtn" Command="{Binding AppendDigitCommand}" CommandParameter="5"/>
            <Button Grid.Row="2" Grid.Column="4" Content="6" Classes="keyBtn" Command="{Binding AppendDigitCommand}" CommandParameter="6"/>
            <!-- Row 3: 7 8 9 -->
            <Button Grid.Row="4" Grid.Column="0" Content="7" Classes="keyBtn" Command="{Binding AppendDigitCommand}" CommandParameter="7"/>
            <Button Grid.Row="4" Grid.Column="2" Content="8" Classes="keyBtn" Command="{Binding AppendDigitCommand}" CommandParameter="8"/>
            <Button Grid.Row="4" Grid.Column="4" Content="9" Classes="keyBtn" Command="{Binding AppendDigitCommand}" CommandParameter="9"/>
            <!-- Row 4: 0 (span 2) + backspace -->
            <Button Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3" Content="0" Classes="keyBtn" Command="{Binding AppendDigitCommand}" CommandParameter="0"/>
            <Button Grid.Row="6" Grid.Column="4" Content="←" Classes="keyBtn" Command="{Binding DeleteDigitCommand}"/>
          </Grid>

          <!-- Error -->
          <Border IsVisible="{Binding HasError}"
                  Background="#fef2f2"
                  BorderBrush="#F87171"
                  BorderThickness="2"
                  CornerRadius="8"
                  Padding="12,10"
                  Margin="0,16,0,0">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#ef4444"
                       FontSize="14"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"/>
          </Border>

          <!-- Login Button -->
          <Button Content="Đăng nhập chủ nhà hàng"
                  Classes="loginBtn"
                  Margin="0,16,0,0"
                  IsEnabled="{Binding CanLogin}"
                  Command="{Binding LoginCommand}"/>

          <!-- Action Buttons Row -->
          <Grid ColumnDefinitions="*,12,*" Margin="0,12,0,0">
            <Button Grid.Column="0" Content="Tắt ứng dụng" Classes="warnBtn"
                    HorizontalAlignment="Stretch"/>
            <Button Grid.Column="2" Content="Xoá PIN" Classes="dangerBtn"
                    HorizontalAlignment="Stretch"
                    Command="{Binding DeleteDigitCommand}"/>
          </Grid>

          <!-- Hint -->
          <Grid ColumnDefinitions="*,Auto" Margin="0,12,0,0">
            <Button Grid.Column="0"
                    Background="Transparent" BorderThickness="0"
                    Foreground="#64748b" FontSize="12"
                    Command="{Binding DeleteDigitCommand}">
              <TextBlock Text="Xoá PIN" TextDecorations="Underline" FontSize="12"/>
            </Button>
            <TextBlock Grid.Column="1" Text="PIN demo: 1105"
                       FontSize="12" Foreground="#64748b"
                       VerticalAlignment="Center"/>
          </Grid>

          <!-- Loading -->
          <ProgressBar IsVisible="{Binding IsBusy}"
                       IsIndeterminate="True"
                       Height="3"
                       Margin="0,12,0,0"/>
        </StackPanel>
      </Border>
    </Grid>
  </Grid>
</UserControl>
